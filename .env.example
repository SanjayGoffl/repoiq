# ========================================
# RepoIQ Environment Variables
# Copy this to .env.local and fill in your values
# ========================================

# === AWS Configuration (Required) ===
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=           # Set in Vercel env vars for production
# AWS_SECRET_ACCESS_KEY=       # Set in Vercel env vars for production

# === Bedrock AI Models ===
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_FALLBACK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_FALLBACK_MODEL_ID_2=amazon.nova-micro-v1:0

# === Bedrock Knowledge Base (Optional - for RAG) ===
BEDROCK_KB_ID=
BEDROCK_KB_DATA_SOURCE_ID=

# === S3 Storage ===
S3_BUCKET_NAME=repoiq-storage
S3_REPO_PREFIX=repos/

# === Application ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAX_REPO_SIZE_MB=50
NEXT_PUBLIC_FREE_QUOTA=10

# === GitHub (Optional but recommended - higher API rate limits) ===
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# === OpenRouter (Optional - parallel AI inference) ===
# Get one at: https://openrouter.ai/keys
openrouter_api_key=
